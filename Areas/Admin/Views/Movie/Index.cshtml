
@model IEnumerable<Movie>
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">All Movies</h2>
        </div>
        <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
            <a href="/Admin/Movie/Create" class="btn btn-success">Create</a>
        </div>
    </div>
    <!-- Filter Section -->
    <section class="py-3 filter-bar">
        <div class="container">
            <div class="row" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;">
                <div class="col-12">
                    <form>
                        <div class="row">
                            <!-- Movie Name -->
                            <div class="col-md-3">
                                <input type="text" class="form-control" placeholder="Movie Name" value="@ViewBag.MovieName" name="MovieName">
                            </div>

                            <!-- Price Range -->
                            <div class="col-md-2">
                                <input type="number" class="form-control" placeholder="Min Price" value="@ViewBag.MinPrice" name="MinPrice">
                            </div>
                            <div class="col-md-2">
                                <input type="number" class="form-control" placeholder="Max Price" value="@ViewBag.MaxPrice" name="MaxPrice">
                            </div>

                            <!-- Category -->
                            <div class="col-md-2">
                                <select name="CategoryId" class="form-control">
                                    <option>--Select Category--</option>
                                    @* @foreach(var item in ViewData["Categories"] as List<Category>)
                                {  
                                    <option>@item.Name</option>
                                } *@
                                    @* @if(ViewData["Categories"] is List<Category> categories)
                                {  
                                        @foreach(var item in categories)
                                        {
                                            <option>@item.Name</option>
                                        }
                                } *@
                                    @foreach (var item in ViewBag.Categories)
                                    {
                                        if (ViewBag.CategoryId == item.Id)
                                        {
                                            <option value="@item.Id" selected>@item.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Id">@item.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <!-- Cinema -->
                            <div class="col-md-2">
                                <select name="CinemaId" class="form-control">
                                    <option>--Select Cinema--</option>
                                    @foreach (var item in ViewBag.Cinemas)
                                    {
                                        if (ViewBag.BrandId == item.Id)
                                        {
                                            <option value="@item.Id" selected>@item.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Id">@item.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <!-- Hot Movie Checkbox -->
                            <div class="col-md-1">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" value="True" name="IsLowQuantity"
                                    @((ViewBag.IsLowQuantity ?? false) ? "checked" : "")>
                                    <label class="form-check-label">Low Quantity</label>
                                </div>
                            </div>

                            <!-- Submit Button -->
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-dark w-100">Filter</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <div class="row">
        <div class="col-12">

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Name</th>
                        <th scope="col">Price</th>
                        <th scope="col">Category Name</th>
                        <th scope="col">Cinema Name </th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <th scope="row">@item.Id</th>
                            <td>@item.Name</td>
                            <td>@item.Price</td>

                            <td>@item.Category.Name</td>
                            <td>@item.Cinema.Name</td>
                         

                            <td>
                                @if (item.Status)
                                {
                                    <span class="badge text-bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge text-bg-danger">
                                        in Active
                                    </span>
                                }
                               
                            </td>
                            @if (User.IsInRole(CD.SUPER_ADMIN_ROLE) || User.IsInRole(CD.ADMIN_ROLE))
                            {
                                <td>
                                    <a href="/Admin/Movie/Update/@item.Id" type="button" class="btn btn-warning">Update</a>
                                    <a href="/Admin/Movie/Delete/@item.Id" class="btn btn-danger btn-delete">Delete</a>
                                </td>
                            }
                            else
                            {
                                <td>
                                    No Permision to delete Or Update!!!!
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <nav aria-label="Page navigation example">
        <div class="d-flex justify-content-center align-items-center">
            <ul class="pagination">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="/Admin/Movie/Index?page=@(ViewBag.CurrentPage - 1)">
                        Previous
                    </a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" href="/Admin/Movie/Index?page=@i">
                            @i
                        </a>
                    </li>
                }
                <li class="page-item  @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="/Admin/Movie/Index?page=@(ViewBag.CurrentPage + 1)">
                        Next
                    </a>
                </li>
            </ul>
        </div>

    </nav>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(btn => {
            btn.addEventListener("click", function (e) {

                e.preventDefault(); // ❌ نمنع اللينك

                const url = this.getAttribute("href");

                const swalWithBootstrapButtons = Swal.mixin({
                    customClass: {
                        confirmButton: "btn btn-success",
                        cancelButton: "btn btn-danger"
                    },
                    buttonsStyling: false
                });

                swalWithBootstrapButtons.fire({
                    title: "Are you sure?",
                    text: "You won't be able to revert this!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes, delete it!",
                    cancelButtonText: "No, cancel!",
                    reverseButtons: true
                }).then((result) => {

                    if (result.isConfirmed) {

                        // 🔥 رسالة النجاح
                        swalWithBootstrapButtons.fire({
                            title: "Deleted!",
                            text: "Movie has been deleted.",
                            icon: "success"
                        }).then(() => {
                            // ✅ تنفيذ الحذف
                            window.location.href = url;
                        });

                    } else if (result.dismiss === Swal.DismissReason.cancel) {

                        swalWithBootstrapButtons.fire({
                            title: "Cancelled",
                            text: "Your data is safe 🙂",
                            icon: "error"
                        });

                    }

                });

            });
        });

    });
</script>