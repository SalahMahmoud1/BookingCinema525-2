
@model MovieVm
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Show All Movie Movie</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <input class="form-control" name="Name" />
                </div>
                <div class="mb-3">
                    <label for="name" class="form-label">Image</label>
                    <input class="form-control" name="ImgFile" type="file" />
                </div>
                <div class="mb-3">
                    <label for="SubImgFiles" class="form-label">Sub Images</label>
                    <input class="form-control" name="SubImgFiles" type="file" multiple />
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <div class="form-floating">
                        <textarea class="form-control" placeholder="Leave a description here" style="height: 100px" name="Description"></textarea>
                        <label for="description">You Description Here...</label>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="Price" class="form-label">Price</label>
                    <input class="form-control" name="Price" type="number" />
                </div>
                <div class="mb-3">
                    <label for="ActorList" class="form-label">Actor List</label>

                    <div id="actorContainer">
                   <!--   <div class="mb-2 d-flex align-item-center">
                            <input type="number" class="form-control form-control-color" name="ActorList1">
                        </div> -->
                        <div class="mb-2 d-flex align-item-center">
                        <select name="ActorList" class="form-select">
                            @foreach (var item in Model.Actors)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                        </div>
                    </div>
                   

                    <button type="button" id="addButtonActor" class="btn btn-outline-primary">+ Add New Actor</button>
                </div>

                
                <div class="mb-3">
                    <label for="status" class="form-label">Category Name</label>
                    <select name="CategoryId" class="form-select">
                        @foreach (var item in Model.Categories)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>

                </div>
                <div class="mb-3">
                    <label for="status" class="form-label">Cinema Name</label>
                    <select name="CinemaId" class="form-select">
                        @foreach (var item in Model.Cinemas)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>

                </div>
                <div class="mb-3">
                    <label for="status" class="form-label">Status</label>
                    <select name="Status" class="form-select">
                        <option value="true" selected>Active</option>
                        <option value="false">InActive</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>
<script>
    const conateiner = document.getElementById('actorContainer');
    const addBtn = document.getElementById('addButtonActor');

    addBtn.addEventListener('click', () => {
        var colorRow = document.createElement('div');

        colorRow.className = 'mb-2 d-flex align-item-center gap-1'
        colorRow.innerHTML = `
              <select name="ActorList" class="form-select">
                            @foreach (var item in Model.Actors)
                            {
                                    <option value="@item.Id">@item.Name</option>
                            }
                        </select>
            <button type="Button" class="btn btn-danger btn-sm removeColor">x</button>
        `;

        conateiner.appendChild(colorRow);
    });

    conateiner.addEventListener('click', (e) => {
        if(e.target.classList.contains('removeColor')) {
            e.target.parentElement.remove();
        }
    })
</script>