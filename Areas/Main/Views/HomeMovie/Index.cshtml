@model List<Movie>
<section class="py-3 filter-bar">
    <div class="container">
        <div class="row" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;">
            <div class="col-12">
                <form>
                    <div class="row">
                        <!-- Movie Name -->
                        <div class="col-md-3">
                            <input type="text" class="form-control" placeholder="Movie Name" value="@ViewBag.MovieName" name="MovieName">
                        </div>

                        <!-- Price Range -->
                        <div class="col-md-2">
                            <input type="number" class="form-control" placeholder="Min Price" value="@ViewBag.MinPrice" name="MinPrice">
                        </div>
                        <div class="col-md-2">
                            <input type="number" class="form-control" placeholder="Max Price" value="@ViewBag.MaxPrice" name="MaxPrice">
                        </div>

                        <!-- Category -->
                        <div class="col-md-2">
                            <select name="CategoryId" class="form-control">
                                <option>--Select Category--</option>
                                @foreach (var item in ViewBag.Categories)
                                {
                                    if (ViewBag.CategoryId == item.Id)
                                    {
                                        <option value="@item.Id" selected>@item.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Id">@item.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <!-- Brand -->
                        <div class="col-md-2">
                            <select name="CinemaId" class="form-control">
                                <option>--Select Cinema--</option>
                                @foreach (var item in ViewBag.Cinemas)
                                {
                                    if (ViewBag.CinemaId == item.Id)
                                    {
                                        <option value="@item.Id" selected>@item.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Id">@item.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <!-- Submit Button -->
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-dark w-100">Filter</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
<div class="container">
    <section class="py-5">
        <div class="container px-4 px-lg-5 mt-5">
            <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
                @foreach (var item in Model)
                {
                    <div class="col mb-5">
                        <div class="card h-60">
                            <!-- Sale badge-->
                            <div class="badge bg-dark text-white position-absolute" style="top: 0.5rem; right: 0.5rem">@item.Category.Name</div>
                           
                            <!-- Product image-->
                            <img class="card-img-top" height="200" src="~/Images/MovieImages/@item.MainImg" alt="..." />
                            <!-- Product details-->
                            <div class="card-body p-4">
                                <div class="text-center">
                                    <!-- Product name-->
                                    <h9 class="fw-bolder">@item.Name</h9>
                                    <!-- Product reviews-->
                                    <div class="d-flex justify-content-center small text-warning mb-2">
                                        @for (int i = 0; i < item.Rate; i++)
                                        {
                                            <div class="bi-star-fill"></div>
                                        }
                                    </div>
                                    <!-- Product price-->
                                    <span class="text-muted ">LE @item.Price</span>
                                </div>
                            </div>
                            <!-- Product actions-->
                            <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                                <div class="text-center"><a class="btn btn-outline-dark mt-auto" href="/Main/HomeMovie/MovieDetails/@item.Id">View</a></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
    <nav aria-label="Page navigation example">
        <div class="d-flex justify-content-center align-items-center">
            <ul class="pagination">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="/Main/HomeMovie/Index?page=@(ViewBag.CurrentPage - 1)">
                        Previous
                    </a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" href="/Main/HomeMovie/Index?page=@i">
                            @i
                        </a>
                    </li>
                }
                <li class="page-item  @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="/Main/HomeMovie/Index?page=@(ViewBag.CurrentPage + 1)">
                        Next
                    </a>
                </li>
            </ul>
        </div>

    </nav>
</div>
@section Scripts {
    <partial name="NotificationPartial" />
}
